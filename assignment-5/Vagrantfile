Vagrant.configure("2") do |config|
  config.vm.box = "utm/ubuntu-24.04"

  # ✅ Port forwarding for each exposed container port
  config.vm.network "forwarded_port", guest: 8080, host: 8080  # Nginx
  config.vm.network "forwarded_port", guest: 8081, host: 8081  # API 1
  config.vm.network "forwarded_port", guest: 8082, host: 8082  # API 2
  config.vm.network "forwarded_port", guest: 5432, host: 5432  # PostgreSQL

  config.vm.provider "utm" do |u|
    u.memory = 2048
    u.cpus = 2
    u.directory_share_mode = "virtFS"
  end

  config.vm.provision "shell", path: "provision.sh"
  config.vm.synced_folder ".", "/home/vagrant/app"
end
